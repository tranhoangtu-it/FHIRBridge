{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@fhirbridge/types": ["../types/src/index.ts"]
    }
  },
  "references": [
    { "path": "../types" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
