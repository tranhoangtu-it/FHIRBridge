{
  "name": "@fhirbridge/cli",
  "version": "0.1.0",
  "description": "Commander.js CLI tool for FHIRBridge patient data export",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fhirbridge": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fhirbridge/core": "workspace:*",
    "@fhirbridge/types": "workspace:*",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.5.0",
    "typescript": "*",
    "vitest": "*"
  },
  "type": "module"
}
