# ============================================================
# FHIRBridge Environment Variables
# Copy to .env and fill in your values. NEVER commit .env!
# ============================================================

# --- Database (Audit logs only — NO PHI stored) ---
DATABASE_URL=postgresql://fhirbridge:changeme@localhost:5432/fhirbridge_audit
POSTGRES_USER=fhirbridge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fhirbridge_audit
POSTGRES_PORT=5432

# --- Redis (Rate limiting + job queues) ---
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# --- API Server ---
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- FHIR HIS Connectors ---
# HIS base URL (hospital information system endpoint)
HIS_BASE_URL=https://his.example.com/fhir/R4
HIS_CLIENT_ID=
HIS_CLIENT_SECRET=
HIS_TOKEN_URL=https://his.example.com/oauth/token

# --- AI Summary Engine ---
# Provider: openai | anthropic
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Security ---
# HMAC secret for de-identification before AI calls (min 32 chars)
DEIDENTIFY_HMAC_SECRET=change-this-to-a-random-32-char-secret
JWT_SECRET=change-this-to-a-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# --- Synthea Test Data ---
SYNTHEA_OUTPUT_DIR=./tests/fixtures/synthea
SYNTHEA_PATIENT_COUNT=10
