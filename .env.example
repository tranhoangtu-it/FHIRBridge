# ============================================================
# FHIRBridge Environment Variables
# Copy to .env and fill in your values. NEVER commit .env!
#
# This is a self-host / open-source distribution. Hospitals and
# clinics run this on their own infrastructure. There is no
# hosted SaaS to subscribe to.
# ============================================================

# --- Database (Audit logs only — NO PHI stored) -------------
# Optional. When unset, audit log goes to stdout (Console sink).
DATABASE_URL=postgresql://fhirbridge:changeme@localhost:5432/fhirbridge_audit
POSTGRES_USER=fhirbridge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fhirbridge_audit
POSTGRES_PORT=5432

# --- Redis (Rate limit + caches) ----------------------------
# Optional. When unset, rate limit + caches are per-process in-memory.
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# --- API server ---------------------------------------------
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- FHIR HIS connector defaults ----------------------------
# Used by CLI / connector test endpoint. UI/api accept overrides per request.
HIS_BASE_URL=https://his.example.com/fhir/R4
HIS_CLIENT_ID=
HIS_CLIENT_SECRET=
HIS_TOKEN_URL=https://his.example.com/oauth/token

# --- AI summary engine (optional) ---------------------------
# Provider: anthropic | openai
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Security (REQUIRED) ------------------------------------
# Both must be at least 32 characters and MUST differ from each other.
JWT_SECRET=change-this-to-a-random-32-char-secret
HMAC_SECRET=change-this-to-a-different-random-32-char-secret
# Comma-separated list of valid static API keys
API_KEYS=
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Rate limiting ------------------------------------------
# Single global budget per authenticated user / IP, default 100 req/min.
RATE_LIMIT_PER_MINUTE=100

# --- Observability ------------------------------------------
# Bearer token guarding /metrics. Leave unset to disable Bearer requirement.
METRICS_BEARER_TOKEN=

# --- Proxy (production behind a load balancer) --------------
# Set to 'true' or a CIDR range, e.g. 10.0.0.0/8
TRUST_PROXY=false

# --- API docs -----------------------------------------------
# Swagger UI is auto-mounted in non-production. Force-enable in production with:
ENABLE_DOCS=false

# --- Synthea test data (development only) -------------------
SYNTHEA_OUTPUT_DIR=./tests/fixtures/synthea
SYNTHEA_PATIENT_COUNT=10
